{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/scan-chunk?offset=0&limit=80",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/scan-chunk?offset=80&limit=80",
      "schedule": "5 0 * * *"
    },
    {
      "path": "/api/cron/scan-chunk?offset=160&limit=100",
      "schedule": "10 0 * * *"
    }
  ],
  "functions": {
    "app/api/scan/route.ts": {
      "maxDuration": 300
    },
    "app/api/scan/retry-failed/route.ts": {
      "maxDuration": 300
    },
    "app/api/cron/scan/route.ts": {
      "maxDuration": 300
    },
    "app/api/cron/scan-chunk/route.ts": {
      "maxDuration": 300
    },
    "app/api/news/preview/route.ts": {
      "maxDuration": 15
    },
    "app/api/quotes/route.ts": {
      "maxDuration": 60
    }
  }
}
