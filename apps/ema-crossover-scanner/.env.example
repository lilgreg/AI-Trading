# Comma-separated symbols (TradingView format supported: NASDAQ:AAPL or plain AAPL)
WATCHLIST_SYMBOLS=

# Shared TradingView watchlist URL (symbols fetched automatically, merged with blue chips)
TRADINGVIEW_WATCHLIST_URL=https://www.tradingview.com/watchlists/156233778/

# Set to "false" to skip the default blue-chip list
INCLUDE_BLUE_CHIPS=true

# How many trading days of history to fetch for EMA calculation
HISTORY_DAYS=120

# TradingView chart layout ID for symbol links
TRADINGVIEW_CHART_LAYOUT=fW1aFTNk

# --- Precomputed scan cache (production) ---

# Cloudflare R2 — required on Vercel for cross-instance cache persistence
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Optional R2 object keys (defaults shown)
# SCAN_CACHE_OBJECT_KEY=ema-scanner/snapshot.json
# SCAN_LOCK_OBJECT_KEY=ema-scanner/scan-lock.json

# Protect /api/cron/scan — Vercel sends Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# Mark cache stale after N minutes (default 15); client triggers rescan when stale
SCAN_STALE_MINUTES=15

# --- Market data (optional backup providers when Yahoo rate-limits) ---

# Yahoo request timeout in ms (default 20000; retries use YAHOO_RETRY_TIMEOUT_MS)
YAHOO_TIMEOUT_MS=20000
YAHOO_RETRY_TIMEOUT_MS=30000

# Optional hourly bar fallbacks (tried in order after Yahoo fails)
FINNHUB_API_KEY=
POLYGON_API_KEY=
TWELVE_DATA_API_KEY=
ALPHA_VANTAGE_API_KEY=

# Testing: skip Yahoo endpoints (requires FINNHUB_API_KEY or other backup)
# CHART_SKIP_YAHOO=1
# Skip slow Yahoo (finance2) — uses yahoo-spark/v8 only
# CHART_SKIP_YAHOO_SLOW=1
