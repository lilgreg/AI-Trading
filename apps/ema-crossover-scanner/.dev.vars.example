# Local Wrangler secrets — copy to .dev.vars (never commit .dev.vars)
NEXTJS_ENV=development

# Required for production scan cache (S3-compatible R2 API)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=ai-trading-scanner

# Required for reliable scans
TRADINGVIEW_WATCHLIST_URL=
FINNHUB_API_KEY=

# Optional
CRON_SECRET=
POLYGON_API_KEY=
TWELVE_DATA_API_KEY=
ALPHA_VANTAGE_API_KEY=
FMP_API_KEY=
WATCHLIST_SYMBOLS=
NEXT_PUBLIC_NEWS_POLL_MS=20000
